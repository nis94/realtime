{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Database=movementintel;Username=movementintel;Password=movementintel",
    "Redis": "localhost:6379"
  },
  "Ingestion": {
    "PositionTtlHours": 72
  },
  "Kafka": {
    "EnableConsumer": false,
    "BootstrapServers": "localhost:9092",
    "Topic": "movement-events",
    "GroupId": "movement-processor",
    "MaxBatchSize": 500,
    "PollTimeoutMs": 100
  }
}
